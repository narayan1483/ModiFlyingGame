<!DOCTYPE html>
<html>
<head>
<title>Register</title>
<link rel="stylesheet" href="css/style.css">
</head>

<body>

<div class="login-box">

<h2>Register</h2>

<form action="register" method="post">

<input type="text" name="username" placeholder="Username" required class="input-box">

<input type="email" name="email" placeholder="Email" required class="input-box">

<input type="password" name="password" placeholder="Password" required class="input-box">

<button type="submit" class="login-btn">Register</button>

</form>
<div class="backHome">
<a href="index.jsp">Back to Home</a>
</div>

<a href="login.jsp">Already have account?</a>

</div>

</body>
</html>